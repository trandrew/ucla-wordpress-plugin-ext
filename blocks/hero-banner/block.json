{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "ucla/hero-banner-block",
  "version": "1.0.0",
  "title": "Hero Banner",
  "category": "ucla-design-system-components-extended",
  "icon": "cover-image",
  "description": "Display a UCLA-style split hero banner with angled panel and CTA.",
  "keywords": ["ucla", "hero", "banner", "cta"],
  "textdomain": "ucla-wordpress-plugin-ext",
  "supports": {
    "align": ["full"]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "headline": {
      "type": "string",
      "default": "Understanding Climate. Building a Better Future."
    },
    "description": {
      "type": "string",
      "default": "We combine field work, data, and modeling to study how ecosystems respond to change."
    },
    "buttonText": {
      "type": "string",
      "default": "Explore Our Research"
    },
    "buttonUrl": {
      "type": "string",
      "default": "#"
    },
    "openInNewTab": {
      "type": "boolean",
      "default": false
    },
    "imageId": {
      "type": "number"
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "render": "file:./render.php"
}
