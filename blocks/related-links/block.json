{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "ucla-wordpress-plugin-ext/related-links",
  "version": "1.0.0",
  "title": "Related Links",
  "category": "ucla-design-system-components-extended",
  "icon": "admin-links",
  "description": "A UCLA Design System styled list of related links.",
  "keywords": ["ucla", "related", "links"],
  "textdomain": "ucla-wordpress-plugin-ext",
  "attributes": {
    "links": {
      "type": "array",
      "default": [
        {
          "text": "Related Link",
          "url": "#",
          "newTab": false
        }
      ]
    },
    "showIcon": {
      "type": "boolean",
      "default": true
    },
    "layout": {
      "type": "string",
      "default": "horizontal"
    },
    "isInserterPreview": {
      "type": "boolean",
      "default": false
    }
  },
  "example": {
    "attributes": {
      "isInserterPreview": true
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}
